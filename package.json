{
  "name": "opendungeon",
  "private": true,
  "version": "0.1.3",
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "npx prisma generate --schema prisma/schema.prisma",
    "db:push": "npx prisma db push --schema prisma/schema.prisma",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "doctor": "node scripts/doctor.mjs",
    "clean:state": "bash scripts/clean-local-state.sh",
    "dev:full": "dotenv -e .env.local -- concurrently -k \"PORT=\\$GATEWAY_PORT pnpm --filter @opendungeon/gateway dev\" \"PORT=\\$WEB_PORT pnpm --filter @opendungeon/web dev\""
  },

  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "devDependencies": {
    "@opendungeon/devtools": "workspace:*",
    "@prisma/client": "^6.0.0",
    "@types/node": "^22.14.1",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.6.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  }
}
