DATABASE_URL=postgresql://od:odpass@localhost:5432/opendungeon
WEB_PORT=3000
GATEWAY_PORT=3001
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001
GAME_MODULE_PATH=./games/game-example
WEB_MODULE_PATH=./web/game-n
CAN_BASIC_ACCOUNT_CREATE_CAMPAIGNS=true
DM_CONTEXT_ROUTER_ENABLED=
DM_CONTEXT_ROUTER_FORCE_LLM=false

# ============================================
# Trace Logging (disabled by default)
# ============================================
ENABLE_TRACE_LOGS=false
ENABLE_TURN_TRACE=false
ENABLE_BACKGROUND_TRACE=false
TURN_TRACE_LOG_FILE=logs/turn-traces.jsonl
BACKGROUND_TRACE_LOG_FILE=logs/background-traces.jsonl

# ============================================
# LLM Provider Configuration
# ============================================
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_ENDPOINT_PATH=
LLM_ANTHROPIC_VERSION=2023-06-01
LLM_EXTRA_HEADERS_JSON=

# Optional separate router model. Leave blank to reuse the main DM provider.
LLM_ROUTER_PROVIDER=
LLM_ROUTER_BASE_URL=
LLM_ROUTER_API_KEY=
LLM_ROUTER_MODEL=
LLM_ROUTER_ENDPOINT_PATH=
LLM_ROUTER_ANTHROPIC_VERSION=
LLM_ROUTER_EXTRA_HEADERS_JSON=

# ============================================
# Gateway Rate Limiting & Performance
# ============================================
# Rate limiting: maximum requests per minute (default: 60)
GATEWAY_LLM_RPM=60

# Rate limiting: window for RPM calculation in ms (default: 60000)
GATEWAY_LLM_RPM_WINDOW_MS=60000

# Concurrency: maximum parallel requests per provider (default: 5)
# If you see slow responses, check semaphore queue depth in logs
GATEWAY_LLM_MAX_CONCURRENT=5

# Retry: maximum retry attempts on error (default: 3)
GATEWAY_LLM_MAX_RETRIES=3

# Retry: base delay in ms (default: 1000)
GATEWAY_LLM_RETRY_BASE_DELAY_MS=1000

# Circuit breaker: errors before opening (default: 5)
GATEWAY_LLM_CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker: recovery timeout in ms (default: 30000)
GATEWAY_LLM_CIRCUIT_BREAKER_RECOVERY_MS=30000

# ============================================
# Archivist (world state normalization)
# ============================================
# Archivist runs an extra LLM call after each DM response to normalize
# world state and summaries. This adds latency (extra 4-15s) but ensures
# consistent world state and auto-generated summaries.
# Set to false for faster responses if you don't need these features.
ENABLE_ARCHIVIST=true

# ============================================
# Fallback Provider (optional)
# ============================================
GATEWAY_LLM_FALLBACK_PROVIDER=
GATEWAY_LLM_FALLBACK_BASE_URL=
GATEWAY_LLM_FALLBACK_API_KEY=
GATEWAY_LLM_FALLBACK_MODEL=
GATEWAY_LLM_FALLBACK_RPM=
